# PostgreSQL
POSTGRES_DB=monitor
POSTGRES_USER=monitor
POSTGRES_PASSWORD=monitor_secret
POSTGRES_PORT=5432

# Server
NODE_ENV=production
API_PORT=5005
TCP_PORT=9000
TLS_ENABLED=true
LOG_LEVEL=info

# Dashboard
DASHBOARD_PORT=3000
VITE_API_URL=http://localhost:5005
VITE_WS_URL=ws://localhost:5005/ws

# Agent
COLLECT_INTERVAL_MS=10000
SECURITY_INTERVAL_MS=15000
SSHD_AUDIT_INTERVAL_MS=3600000
PORT_SCAN_INTERVAL_MS=60000
FIREWALL_INTERVAL_MS=3600000
HARDENING_INTERVAL_MS=3600000
LOGIN_ACTIVITY_INTERVAL_MS=60000
